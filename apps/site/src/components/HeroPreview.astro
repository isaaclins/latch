  <text x="20" y="136" font-family="Inter Variable, Inter, sans-serif" font-size="12" fill="#5C6370">Snoozed</text>
  <text x="128" y="136" font-family="JetBrains Mono, monospace" font-size="11" fill="#8A8F98" text-anchor="end">7</text>

  <!-- thread rows -->
  <!-- selected row -->
  <rect x="148" y="56" width="332" height="48" fill="#EEEAFD" />
  <rect x="148" y="56" width="3" height="48" fill="#5448E6" />
  <text x="164" y="76" font-family="Inter Variable, Inter, sans-serif" font-size="12" font-weight="500" fill="#0A0B0D">Re: Q3 invoice draft — needs your sign-off</text>
