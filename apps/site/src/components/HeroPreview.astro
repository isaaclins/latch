  viewBox="0 0 480 320"
  role="img"
  aria-label="Latch app preview: a triage queue showing four threads, one selected, with quick actions on the right."
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- card -->
  <rect x="0.5" y="0.5" width="479" height="319" rx="10" fill="#FFFFFF" stroke="#E6E7EB" />

  <!-- top chrome -->
  <line x1="0" y1="40" x2="480" y2="40" stroke="#E6E7EB" />
  <circle cx="18" cy="20" r="4" fill="#E6E7EB" />
  <circle cx="32" cy="20" r="4" fill="#E6E7EB" />
  <circle cx="46" cy="20" r="4" fill="#E6E7EB" />
